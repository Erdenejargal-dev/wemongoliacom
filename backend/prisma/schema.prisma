generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  traveler
  provider_owner
  admin
}

enum ProviderType {
  tour_operator
  car_rental
  accommodation
}

enum OnboardingStatus {
  draft
  submitted
  approved
}

enum ListingStatus {
  draft
  active
  paused
  archived
}

enum VerificationStatus {
  unverified
  pending_review
  verified
  rejected
}

enum VehicleStatus {
  draft
  active
  paused
  maintenance
  archived
}

enum DepartureStatus {
  scheduled
  sold_out
  cancelled
}

enum BlockStatus {
  available
  booked
  blocked
  maintenance
}

enum RoomAvailabilityStatus {
  available
  sold_out
  blocked
}

enum ListingType {
  tour
  vehicle
  accommodation
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

/// Phase 6 — BookingRequest is a lightweight lead created when a listing is
/// not directly payable today (e.g. USD-priced listing before Visa launches).
/// It is NOT a booking: no inventory is held, no money is calculated, no FX
/// snapshot is taken. The provider contacts the traveler to arrange payment
/// and, once agreed, creates a real Booking through the normal flow.
enum BookingRequestStatus {
  new         // just submitted, provider has not reviewed yet
  in_review   // provider opened it / is contacting the traveler
  accepted    // provider agreed; a real Booking should follow
  declined    // provider could not accommodate
  expired     // auto-closed after inactivity (operational hygiene)
}

enum PaymentStatus {
  unpaid
  authorized
  paid
  refunded
  failed
}

enum PaymentAttemptStatus {
  initiated
  redirected
  failed
  superseded
}

enum PayoutStatus {
  pending
  scheduled
  paid
  failed
}

enum SenderRole {
  traveler
  provider
}

enum PriceType {
  per_person
  private_group
  fixed
}

enum Difficulty {
  Easy
  Moderate
  Challenging
}

enum VehicleType {
  SUV
  Van
  Minibus
  Sedan
  FourByFour
}

enum Transmission {
  Manual
  Automatic
}

enum AccommodationType {
  ger_camp
  hotel
  lodge
  guesthouse
  resort
  hostel
  homestay
}

enum PlanType {
  FREE
  PRO
}

// ─────────────────────────────────────────────
// MODEL: User
// ─────────────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String   @unique
  passwordHash      String
  phone             String?
  country           String?
  avatarUrl         String?
  avatarPublicId    String?
  bio               String?
  role              UserRole @default(traveler)
  isVerified        Boolean  @default(false)
  // Phase 2 Option B: optional user preferences for currency/language.
  // Null = auto-detect from country (handled in app/frontend).
  // Only values in SUPPORTED_CURRENCIES / ('mn'|'en') are accepted at
  // service boundaries.
  preferredCurrency String?
  preferredLanguage String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  provider            Provider?
  providerOnboarding  ProviderOnboarding?
  bookings            Booking[]
  bookingRequests     BookingRequest[]
  conversations       Conversation[]
  messages            Message[]
  reviews             Review[]
  wishlistItems       WishlistItem[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  payments            Payment[]

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────
// MODEL: PasswordResetToken
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// MODEL: ProviderOnboarding
// ─────────────────────────────────────────────

model ProviderOnboarding {
  id            String           @id @default(cuid())
  ownerUserId   String           @unique
  businessName  String?
  description   String?
  location      String?
  phone         String?
  email         String?
  website       String?
  languages     String[]
  providerTypes ProviderType[]
  logoUrl       String?
  logoPublicId  String?
  coverImageUrl String?
  coverPublicId String?
  stepCompleted Int              @default(0)
  status        OnboardingStatus @default(draft)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@map("provider_onboardings")
}

// ─────────────────────────────────────────────
// MODEL: Provider
// ─────────────────────────────────────────────

model Provider {
  id                 String             @id @default(cuid())
  ownerUserId        String             @unique
  name               String
  slug               String             @unique
  description        String?
  logoUrl            String?
  logoPublicId       String?
  coverImageUrl      String?
  coverPublicId      String?
  email              String?
  phone              String?
  website            String?
  city               String?
  region             String?
  country            String             @default("Mongolia")
  address            String?
  languages          String[]
  providerTypes      ProviderType[]
  ratingAverage      Float              @default(0)
  reviewsCount       Int                @default(0)
  totalGuestsHosted  Int                @default(0)
  isVerified         Boolean            @default(false)
  verificationStatus VerificationStatus @default(unverified)
  rejectionReason    String?
  reviewedAt         DateTime?
  plan               PlanType           @default(FREE)
  status             ListingStatus      @default(draft)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  owner          User            @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  tours          Tour[]
  vehicles       Vehicle[]
  accommodations Accommodation[]
  bookings       Booking[]
  bookingRequests BookingRequest[]
  conversations  Conversation[]
  payouts        Payout[]

  @@index([slug])
  @@index([providerTypes])
  @@map("providers")
}

// ─────────────────────────────────────────────
// MODEL: Destination
// ─────────────────────────────────────────────

model Destination {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  country           String   @default("Mongolia")
  region            String?
  shortDescription  String?
  description       String?
  heroImageUrl      String?
  heroImagePublicId String?
  gallery           String[]
  highlights        String[]
  activities        String[]
  tips              String[]
  bestTimeToVisit   String?
  weatherInfo       String?
  featured          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tours          Tour[]
  vehicles       Vehicle[]
  accommodations Accommodation[]

  @@index([slug])
  @@index([featured])
  @@map("destinations")
}

// ─────────────────────────────────────────────
// MODEL: Tour
// ─────────────────────────────────────────────

model Tour {
  id                 String      @id @default(cuid())
  providerId         String
  destinationId      String?
  slug               String      @unique
  title              String
  shortDescription   String?
  description        String?
  category           String?
  experienceType     String?
  durationDays       Int?
  durationNights     Int?
  difficulty         Difficulty?
  meetingPoint       String?
  pickupIncluded     Boolean     @default(false)
  cancellationPolicy String?
  languages          String[]
  maxGuests          Int         @default(12)
  minGuests          Int         @default(1)
  ageRestrictions    String?
  priceType          PriceType   @default(per_person)
  basePrice          Float
  currency           String      @default("USD")

  // Phase 2 Option B — multi-currency canonical pricing.
  // `baseAmount`/`baseCurrency` are the source of truth for new writes.
  // Legacy `basePrice`/`currency` are dual-written for one release cycle,
  // then dropped in a follow-up migration.
  // `normalizedAmountMnt` is a cached conversion used by search/sort/filter
  // so we never compare raw numbers across different currencies.
  baseAmount          Float?
  baseCurrency        String?
  normalizedAmountMnt Float?
  normalizedFxRate    Float?
  normalizedFxRateAt  DateTime?

  ratingAverage Float         @default(0)
  reviewsCount  Int           @default(0)
  status        ListingStatus @default(draft)
  featured      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  images        TourImage[]
  itinerary     TourItineraryDay[]
  includedItems TourIncludedItem[]
  excludedItems TourExcludedItem[]
  departures    TourDeparture[]

  @@index([providerId])
  @@index([destinationId])
  @@index([status])
  @@index([featured])
  @@index([basePrice])
  @@index([normalizedAmountMnt])
  @@index([ratingAverage])
  @@map("tours")
}

model TourImage {
  id        String  @id @default(cuid())
  tourId    String
  imageUrl  String
  publicId  String?
  altText   String?
  width     Int?
  height    Int?
  format    String?
  bytes     Int?
  sortOrder Int     @default(0)

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@map("tour_images")
}

model TourItineraryDay {
  id                String  @id @default(cuid())
  tourId            String
  dayNumber         Int
  title             String
  description       String?
  overnightLocation String?

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@map("tour_itinerary_days")
}

model TourIncludedItem {
  id     String @id @default(cuid())
  tourId String
  label  String

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@map("tour_included_items")
}

model TourExcludedItem {
  id     String @id @default(cuid())
  tourId String
  label  String

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@map("tour_excluded_items")
}

// ─────────────────────────────────────────────
// MODEL: TourDeparture
// ─────────────────────────────────────────────

model TourDeparture {
  id                   String          @id @default(cuid())
  tourId               String
  startDate            DateTime
  endDate              DateTime
  availableSeats       Int
  bookedSeats          Int             @default(0)
  priceOverride        Float?
  currency             String          @default("USD")
  // Phase 2 Option B — currency-aware override. baseOverrideAmount is the
  // canonical override price in baseOverrideCurrency. Legacy priceOverride
  // is dual-written (same value when override currency matches legacy
  // currency field) until the drop-legacy migration ships.
  baseOverrideAmount   Float?
  baseOverrideCurrency String?
  status               DepartureStatus @default(scheduled)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  tour     Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([tourId])
  @@index([startDate])
  @@index([status])
  @@map("tour_departures")
}

// ─────────────────────────────────────────────
// MODEL: Vehicle
// ─────────────────────────────────────────────

model Vehicle {
  id                 String        @id @default(cuid())
  providerId         String
  destinationId      String?
  slug               String        @unique
  title              String
  description        String?
  vehicleType        VehicleType?
  make               String?
  model              String?
  year               Int?
  transmission       Transmission?
  seats              Int           @default(4)
  luggageCapacity    Int?
  withDriver         Boolean       @default(false)
  fuelPolicy         String?
  cancellationPolicy String?
  features           String[]
  pricePerDay        Float
  currency           String        @default("USD")

  // Phase 2 Option B — see Tour for semantics. baseAmount/baseCurrency
  // replaces pricePerDay/currency as source of truth; normalizedAmountMnt
  // powers search/sort.
  baseAmount          Float?
  baseCurrency        String?
  normalizedAmountMnt Float?
  normalizedFxRate    Float?
  normalizedFxRateAt  DateTime?

  ratingAverage Float         @default(0)
  reviewsCount  Int           @default(0)
  status        VehicleStatus @default(draft)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  images       VehicleImage[]
  availability VehicleAvailability[]

  @@index([providerId])
  @@index([destinationId])
  @@index([status])
  @@index([normalizedAmountMnt])
  @@map("vehicles")
}

model VehicleImage {
  id        String  @id @default(cuid())
  vehicleId String
  imageUrl  String
  publicId  String?
  altText   String?
  width     Int?
  height    Int?
  format    String?
  bytes     Int?
  sortOrder Int     @default(0)

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_images")
}

// ─────────────────────────────────────────────
// MODEL: VehicleAvailability
// ─────────────────────────────────────────────

model VehicleAvailability {
  id                   String      @id @default(cuid())
  vehicleId            String
  startDate            DateTime
  endDate              DateTime
  status               BlockStatus @default(available)
  priceOverride        Float?
  // Phase 2 Option B — currency-aware override. priceOverride alone is
  // ambiguous (no currency side car on VehicleAvailability in Phase 1);
  // baseOverrideAmount/baseOverrideCurrency now carry the full semantic.
  baseOverrideAmount   Float?
  baseOverrideCurrency String?
  note                 String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([vehicleId])
  @@index([startDate, endDate])
  @@map("vehicle_availability")
}

// ─────────────────────────────────────────────
// MODEL: Accommodation
// ─────────────────────────────────────────────

model Accommodation {
  id                 String            @id @default(cuid())
  providerId         String
  destinationId      String?
  slug               String            @unique
  name               String
  description        String?
  accommodationType  AccommodationType @default(ger_camp)
  address            String?
  city               String?
  region             String?
  latitude           Float?
  longitude          Float?
  checkInTime        String?
  checkOutTime       String?
  amenities          String[]
  cancellationPolicy String?
  starRating         Int?
  ratingAverage      Float             @default(0)
  reviewsCount       Int               @default(0)
  status             ListingStatus     @default(draft)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  images    AccommodationImage[]
  roomTypes RoomType[]

  @@index([providerId])
  @@index([destinationId])
  @@index([status])
  @@map("accommodations")
}

model AccommodationImage {
  id              String  @id @default(cuid())
  accommodationId String
  imageUrl        String
  publicId        String?
  altText         String?
  width           Int?
  height          Int?
  format          String?
  bytes           Int?
  sortOrder       Int     @default(0)

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@index([accommodationId])
  @@map("accommodation_images")
}

// ─────────────────────────────────────────────
// MODEL: RoomType
// ─────────────────────────────────────────────

model RoomType {
  id                String  @id @default(cuid())
  accommodationId   String
  name              String
  description       String?
  maxGuests         Int     @default(2)
  bedType           String?
  quantity          Int     @default(1)
  basePricePerNight Float
  currency          String  @default("USD")

  // Phase 2 Option B — see Tour for semantics. baseAmount/baseCurrency
  // replaces basePricePerNight/currency as source of truth;
  // normalizedAmountMnt powers search/sort.
  baseAmount          Float?
  baseCurrency        String?
  normalizedAmountMnt Float?
  normalizedFxRate    Float?
  normalizedFxRateAt  DateTime?

  amenities String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accommodation Accommodation      @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  availability  RoomAvailability[]
  bookings      Booking[]
  images        RoomTypeImage[]

  @@index([accommodationId])
  @@index([normalizedAmountMnt])
  @@map("room_types")
}

// ─────────────────────────────────────────────
// MODEL: RoomTypeImage
// Separate from AccommodationImage — room-level
// photos (specific ger/room interior), not the
// property-level gallery.
// ─────────────────────────────────────────────

model RoomTypeImage {
  id         String  @id @default(cuid())
  roomTypeId String
  imageUrl   String
  publicId   String?
  altText    String?
  width      Int?
  height     Int?
  format     String?
  bytes      Int?
  sortOrder  Int     @default(0)

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@index([roomTypeId])
  @@map("room_type_images")
}

// ─────────────────────────────────────────────
// MODEL: RoomAvailability
// ─────────────────────────────────────────────

model RoomAvailability {
  id                   String                 @id @default(cuid())
  roomTypeId           String
  date                 DateTime               @db.Date
  availableUnits       Int
  bookedUnits          Int                    @default(0)
  priceOverride        Float?
  // Phase 2 Option B — currency-aware override. priceOverride alone has
  // no currency sidecar on Phase 1 (inherits the parent roomType currency);
  // baseOverrideAmount/baseOverrideCurrency now carry the full semantic.
  baseOverrideAmount   Float?
  baseOverrideCurrency String?
  status               RoomAvailabilityStatus @default(available)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  roomType RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([roomTypeId, date])
  @@index([roomTypeId])
  @@index([date])
  @@map("room_availability")
}

// ─────────────────────────────────────────────
// MODEL: Booking
// listingType + listingId are plain strings; polymorphic
// lookups are handled in application code.
// ─────────────────────────────────────────────

model Booking {
  id          String @id @default(cuid())
  bookingCode String @unique
  userId      String
  providerId  String

  // Polymorphic listing (resolved in app code, no FK)
  listingType ListingType
  listingId   String

  // Inventory references
  tourDepartureId       String?
  vehicleAvailabilityId String?
  roomTypeId            String?

  // Dates
  startDate DateTime
  endDate   DateTime?
  nights    Int?
  guests    Int       @default(1)
  adults    Int       @default(1)
  children  Int       @default(0)
  quantity  Int       @default(1)

  // Pricing — charge-currency view (what the payment gateway sees).
  // For MNT Bonum bookings, `currency` is 'MNT' and all amounts are in MNT.
  subtotal       Float
  serviceFee     Float
  taxes          Float  @default(0)
  discountAmount Float  @default(0)
  totalAmount    Float
  currency       String @default("USD")

  // ── Phase 2 Option B — FX + base-currency snapshot ─────────────────────
  // A booking row must be fully reproducible from its own columns even if
  // exchange rates change tomorrow. `listingSnapshot` JSON is supplemental
  // for display metadata only — it is NOT authoritative for money.
  //
  // `pricePerUnitAmount`/`units` are first-class mirrors of what was used
  // to compute subtotal (price per seat/night/day × count).
  //
  // `baseCurrency` is the listing's native currency at booking time, which
  // may differ from `currency` (charge currency). `fxRate` converts
  // 1 baseCurrency → fxRate · chargeCurrency. For same-currency bookings
  // fxRate = 1 and `fxRateSource` = 'same_currency'.
  pricePerUnitAmount Float?
  units              Int?
  baseCurrency       String?
  baseSubtotal       Float?
  baseServiceFee     Float?
  baseTotalAmount    Float?
  fxRate             Float?
  fxRateCapturedAt   DateTime?
  fxRateSource       String?

  // Statuses
  bookingStatus BookingStatus @default(pending)
  paymentStatus PaymentStatus @default(unpaid)

  // Cancellation
  cancelledAt  DateTime?
  cancelReason String?
  completedAt  DateTime?

  // Traveler snapshot
  travelerFullName String?
  travelerEmail    String?
  travelerPhone    String?
  travelerCountry  String?
  specialRequests  String?

  listingSnapshot Json

  holdExpiresAt        DateTime?
  maxHoldUntil         DateTime?
  lastPaymentAttemptAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  provider            Provider             @relation(fields: [providerId], references: [id], onDelete: Restrict)
  tourDeparture       TourDeparture?       @relation(fields: [tourDepartureId], references: [id], onDelete: SetNull)
  vehicleAvailability VehicleAvailability? @relation(fields: [vehicleAvailabilityId], references: [id], onDelete: SetNull)
  roomType            RoomType?            @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)
  roomAvailability    RoomAvailability?    @relation(fields: [roomAvailabilityId], references: [id], onDelete: SetNull)

  roomAvailabilityId String?

  payment       Payment?
  review        Review?
  conversation  Conversation?
  webhookEvents WebhookEvent[]

  @@index([userId])
  @@index([providerId])
  @@index([listingType, listingId])
  @@index([bookingStatus])
  @@index([startDate])
  @@index([holdExpiresAt])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// MODEL: BookingRequest (Phase 6 — UX + Growth)
//
// A lead for listings that cannot be paid through current processors
// (today: any non-MNT listing, because Bonum is MNT-only). The traveler
// submits their contact details + preferred dates; the provider follows
// up out-of-band and, if accepted, creates a real Booking through the
// normal flow.
//
// This model is INTENTIONALLY SEPARATE from Booking. It does not touch
// pricing, FX, or inventory. See `backend/src/services/booking-request.service.ts`.
// ─────────────────────────────────────────────

model BookingRequest {
  id         String @id @default(cuid())

  // Who is requesting. Auth is optional: we allow unauthenticated leads so
  // that first-time foreign visitors can submit interest without signing up,
  // but we keep the user link when present for later linking into a real Booking.
  userId     String?
  providerId String

  // What they want
  listingType ListingType
  listingId   String

  // Traveler-supplied contact info (captured even when logged in, because a
  // request can be submitted from the booking card before auth).
  name    String
  email   String
  phone   String?
  message String?

  // Requested dates / party size — free-form numbers because this is a lead,
  // not a booking. `endDate` is optional (single-day activities).
  startDate  DateTime?
  endDate    DateTime?
  guests     Int?
  quantity   Int?

  // Currency the listing is priced in (MNT or USD today). Stored so the
  // provider sees the currency the traveler was quoted in, even after the
  // listing is re-priced later.
  listingCurrency String?

  status     BookingRequestStatus @default(new)
  providerNote String?

  // Minimal audit metadata
  ipAddress  String?
  userAgent  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reviewedAt DateTime?

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, status])
  @@index([userId])
  @@index([listingType, listingId])
  @@index([createdAt])
  @@map("booking_requests")
}

// ─────────────────────────────────────────────
// MODEL: Payment
// ─────────────────────────────────────────────

model Payment {
  id               String        @id @default(cuid())
  bookingId        String        @unique
  providerId       String
  userId           String
  paymentGateway   String        @default("bonum")
  paymentReference String?
  amount           Float
  currency         String        @default("USD")
  status           PaymentStatus @default(unpaid)
  refundAmount     Float?
  refundReason     String?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  providerOrderId    String?   @unique
  bonumTransactionId String?   @unique
  sessionExpiresAt   DateTime?
  followUpUrl        String?
  idempotencyKey     String?   @unique
  metadata           Json?
  failedAt           DateTime?
  failureCode        String?
  failureMessage     String?
  refundQueuedAt     DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  attempts      PaymentAttempt[]
  webhookEvents WebhookEvent[]

  @@index([bookingId])
  @@index([userId])
  @@index([providerOrderId])
  @@map("payments")
}

// ─────────────────────────────────────────────
// MODEL: PaymentAttempt
// ─────────────────────────────────────────────

model PaymentAttempt {
  id              String               @id @default(cuid())
  paymentId       String
  attemptNumber   Int
  status          PaymentAttemptStatus @default(initiated)
  idempotencyKey  String               @unique
  providerOrderId String?
  followUpUrl     String?
  qrPayload       String?
  deeplinkUrl     String?
  expiresAt       DateTime?
  createdAt       DateTime             @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_attempts")
}

// ─────────────────────────────────────────────
// MODEL: WebhookEvent
// ─────────────────────────────────────────────

model WebhookEvent {
  id             String    @id @default(cuid())
  provider       String    @default("bonum")
  eventId        String    @unique
  bookingId      String?
  paymentId      String?
  rawPayload     Json
  signatureValid Boolean   @default(false)
  processed      Boolean   @default(false)
  processedAt    DateTime?
  error          String?
  createdAt      DateTime  @default(now())

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([processed, createdAt])
  @@map("webhook_events")
}

// ─────────────────────────────────────────────
// MODEL: Payout
// ─────────────────────────────────────────────

model Payout {
  id              String       @id @default(cuid())
  providerId      String
  bookingId       String?
  grossAmount     Float
  platformFee     Float
  payoutAmount    Float
  currency        String       @default("USD")
  status          PayoutStatus @default(pending)
  payoutReference String?
  paidAt          DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@index([providerId])
  @@index([status])
  @@map("payouts")
}

// ─────────────────────────────────────────────
// MODEL: Conversation
// ─────────────────────────────────────────────

model Conversation {
  id                  String       @id @default(cuid())
  travelerId          String
  providerId          String
  listingType         ListingType?
  listingId           String?
  bookingId           String?      @unique
  lastMessageAt       DateTime     @default(now())
  lastMessagePreview  String?
  travelerUnreadCount Int          @default(0)
  providerUnreadCount Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  traveler User      @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  provider Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([travelerId, providerId])
  @@index([travelerId])
  @@index([providerId])
  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}

// ─────────────────────────────────────────────
// MODEL: Message
// ─────────────────────────────────────────────

model Message {
  id             String     @id @default(cuid())
  conversationId String
  senderId       String
  senderRole     SenderRole
  text           String
  attachments    String[]
  isRead         Boolean    @default(false)
  readAt         DateTime?
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

// ─────────────────────────────────────────────
// MODEL: Review
// One per completed booking. listingId is a plain
// string — polymorphic lookups handled in app code.
// ─────────────────────────────────────────────

model Review {
  id            String      @id @default(cuid())
  bookingId     String      @unique
  userId        String
  providerId    String
  listingType   ListingType
  listingId     String
  rating        Int
  title         String?
  comment       String?
  providerReply String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingType, listingId])
  @@index([userId])
  @@index([providerId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// MODEL: WishlistItem
// listingId is a plain string — resolved in app code.
// ─────────────────────────────────────────────

model WishlistItem {
  id          String      @id @default(cuid())
  userId      String
  listingType ListingType
  listingId   String
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingType, listingId])
  @@index([userId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────
// MODEL: Notification
// ─────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  actionUrl String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// MODEL: FxRate (Phase 2 Option B)
//
// Admin-managed exchange rate table. Rates are IMMUTABLE once written —
// corrections create a new row with a later effectiveFrom. `getActiveRate`
// (backend/src/utils/fx.ts) reads the latest row with effectiveFrom <= now
// for the requested (fromCurrency, toCurrency) pair.
//
// Same-currency conversions never hit this table — they short-circuit with
// rate=1, source='same_currency'.
// ─────────────────────────────────────────────

model FxRate {
  id            String   @id @default(cuid())
  fromCurrency  String
  toCurrency    String
  rate          Float
  effectiveFrom DateTime
  source        String
  note          String?
  createdById   String?
  createdAt     DateTime @default(now())

  @@index([fromCurrency, toCurrency, effectiveFrom])
  @@map("fx_rates")
}

// ─────────────────────────────────────────────
// MODEL: FxBackfillReport (Phase 2 Option B)
//
// Data-quality log written by the backfill migration. One row per record
// that could not be automatically classified (unknown currency, mismatch
// between booking.currency and listing.baseCurrency, override without a
// currency parent, etc). Admins resolve these manually before the
// drop-legacy migration ships.
// ─────────────────────────────────────────────

model FxBackfillReport {
  id         String    @id @default(cuid())
  entityType String
  entityId   String
  issue      String
  context    Json?
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([resolvedAt])
  @@map("fx_backfill_reports")
}
